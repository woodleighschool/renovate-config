{
  $schema: "https://docs.renovatebot.com/renovate-schema.json",
  postUpgradeTasks: {
    commands: [
      "helm-docs --chart-search-root=. --log-level=warn",
      "helm-schema --chart-search-root . --skip-auto-generation required,additionalProperties --append-newline",
    ],
    fileFilters: [
      "charts/*/README.md",
      "charts/*/values.schema.json",
      "deploy/helm/*/README.md",
      "deploy/helm/*/values.schema.json",
    ],
    executionMode: "branch",
  },
}
